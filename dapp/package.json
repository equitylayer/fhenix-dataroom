{
	"name": "fhenix-dataroom-dapp",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:stack": "bash scripts/deploy-local.sh && vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"pull-abis": "node scripts/pull-abis.js ../contracts && yarn gen",
		"pull-abis:staging": "node scripts/pull-abis.js ../contracts --chain-id 84532 && yarn gen",
		"gen": "typechain --target=ethers-v6 --out-dir src/types ./src/assets/abis/*.json"
	},
	"dependencies": {
		"@cofhe/sdk": "^0.4.0",
		"@radix-ui/react-slot": "^1.2.3",
		"@rainbow-me/rainbowkit": "^2.2.10",
		"@storacha/client": "^2.1.2",
		"@tailwindcss/vite": "^4.1.14",
		"@tanstack/react-query": "^5.90.10",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"ethers": "^6.15.0",
		"lucide-react": "^0.577.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwind-merge": "^3.3.1",
		"tailwindcss": "^4.1.14",
		"viem": "^2.40.0",
		"wagmi": "^2.19.5"
	},
	"devDependencies": {
		"@typechain/ethers-v6": "^0.5.1",
		"@types/node": "^25.3.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.1.9",
		"@vitejs/plugin-react-swc": "^4.1.0",
		"tw-animate-css": "^1.4.0",
		"typechain": "^8.3.2",
		"typescript": "~5.9.3",
		"vite": "^7.2.7"
	}
}
